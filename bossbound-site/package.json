<!doctype html>
<html lang="nl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Bossbound — Boss Rush RPG</title>
  <meta name="description" content="Bossbound is een dark fantasy Boss Rush RPG. Binnenkort beschikbaar." />
  <meta name="theme-color" content="#120819" />
  <meta property="og:title" content="Bossbound — Boss Rush RPG" />
  <meta property="og:description" content="Face impossible foes. Claim legendary power. Coming soon." />
  <meta property="og:image" content="assets/images/bossbound-startscreen.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="css/style.css" />
</head>
<body>
  <div class="noise"></div>
  <header class="site-header" id="top">
    <a class="brand" href="#top" aria-label="Bossbound home">
      <span class="brand-mark">✦</span>
      <span>Bossbound</span>
    </a>
    <button class="nav-toggle" aria-label="Menu openen" aria-expanded="false">☰</button>
    <nav class="nav" aria-label="Hoofdnavigatie">
      <a href="#game">Game</a>
      <a href="#features">Features</a>
      <a href="#characters">Characters</a>
      <a href="#media">Media</a>
      <a href="#signup">Updates</a>
    </nav>
    <a class="header-cta" href="#signup">Wishlist</a>
  </header>

  <main>
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-bg" role="img" aria-label="Bossbound dark fantasy start screen"></div>
      <div class="hero-vignette"></div>
      <div class="hero-content">
        <p class="eyebrow">Boss Rush RPG</p>
        <h1 id="hero-title">Bossbound</h1>
        <div class="soon-badge">✦ Coming Soon ✦</div>
        <p class="hero-text">Face impossible foes. Claim legendary power. Build your party and descend deeper into a gothic dungeon where every run becomes a fight for survival.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="#signup">Wishlist now</a>
          <a class="btn btn-secondary" href="#media">Bekijk screenshots</a>
        </div>
      </div>
    </section>

    <section class="image-strip" id="features" aria-label="Bossbound features">
      <img src="assets/images/features-strip.png" alt="Epic boss fights, endless progression, legendary loot en dark fantasy features" />
    </section>

    <section class="section split" id="game">
      <div class="panel panel-large">
        <p class="eyebrow">Game overview</p>
        <h2>A world of endless challenge</h2>
        <p>Bossbound is een dark fantasy boss-rush RPG waarin je geen lange filler-levels speelt, maar direct tegenover gigantische eindbazen staat. Leer patronen, kies je build, verzamel relics en probeer steeds verder te komen.</p>
        <div class="feature-grid">
          <article>
            <span class="rune">✦</span>
            <h3>Brutal boss battles</h3>
            <p>Cinematische gevechten met unieke mechanics, phases en beloningen.</p>
          </article>
          <article>
            <span class="rune">✧</span>
            <h3>Replayable runs</h3>
            <p>Elke run voelt anders door skills, gear, buffs en dungeon modifiers.</p>
          </article>
          <article>
            <span class="rune">◆</span>
            <h3>Unique builds</h3>
            <p>Combineer classes, wapens en relics tot jouw perfecte party.</p>
          </article>
          <article>
            <span class="rune">◇</span>
            <h3>Legendary loot</h3>
            <p>Ontgrendel zeldzame items waarmee je nieuwe strategieën opent.</p>
          </article>
        </div>
      </div>
      <aside class="panel preview-card">
        <img src="assets/images/bossbound-startscreen.png" alt="Bossbound startscherm met heroes en dungeon boss" />
      </aside>
    </section>

    <section class="section" id="characters">
      <div class="section-heading">
        <p class="eyebrow">Choose your champion</p>
        <h2>Characters</h2>
        <p>Kies je helden, bouw synergie en overleef de boss rush.</p>
      </div>
      <div class="characters-layout">
        <img class="wide-art" src="assets/images/heroes-panel.png" alt="Bossbound heroes: Warrior, Mage en Cleric" />
        <div class="cards">
          <article class="class-card">
            <span class="class-icon">⚔</span>
            <h3>Warrior</h3>
            <p>Frontline fighter met hoge durability, counters en zware strikes.</p>
          </article>
          <article class="class-card">
            <span class="class-icon">✹</span>
            <h3>Mage</h3>
            <p>Master of elemental magic, burst damage en arcane destruction.</p>
          </article>
          <article class="class-card">
            <span class="class-icon">✚</span>
            <h3>Cleric</h3>
            <p>Healer en support met divine power, shields en revival skills.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section media" id="media">
      <div class="section-heading">
        <p class="eyebrow">Media</p>
        <h2>Screenshots</h2>
        <p>De stijl van de site is gebaseerd op jouw Bossbound startscherm en de meegeleverde panels.</p>
      </div>
      <div class="gallery">
        <a href="assets/images/bossbound-startscreen.png" target="_blank" rel="noopener"><img src="assets/images/bossbound-startscreen.png" alt="Bossbound startscherm" /></a>
        <a href="assets/images/heroes-panel.png" target="_blank" rel="noopener"><img src="assets/images/heroes-panel.png" alt="Bossbound characters panel" /></a>
        <a href="assets/images/join-adventure.png" target="_blank" rel="noopener"><img src="assets/images/join-adventure.png" alt="Join the adventure panel" /></a>
        <a href="assets/images/site-preview.png" target="_blank" rel="noopener"><img src="assets/images/site-preview.png" alt="Bossbound website preview" /></a>
      </div>
    </section>

    <section class="section signup" id="signup">
      <div class="signup-bg"></div>
      <div class="panel signup-panel">
        <p class="eyebrow">Join the adventure</p>
        <h2>Blijf op de hoogte</h2>
        <p>Bossbound is nog in ontwikkeling. Laat je e-mailadres achter voor nieuws over demo’s, screenshots en release-updates.</p>
        <form name="bossbound-updates" method="POST" data-netlify="true" class="signup-form">
          <input type="hidden" name="form-name" value="bossbound-updates" />
          <label class="sr-only" for="email">E-mailadres</label>
          <input id="email" name="email" type="email" placeholder="Jouw e-mailadres" required />
          <button class="btn btn-primary" type="submit">Subscribe</button>
        </form>
        <p class="mini-note">Werkt direct op Netlify via Netlify Forms.</p>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="brand footer-brand"><span class="brand-mark">✦</span><span>Bossbound</span></div>
    <p>Boss Rush RPG · Fight. Die. Learn. Ascend.</p>
    <div class="footer-links">
      <a href="https://github.com/" target="_blank" rel="noopener">GitHub</a>
      <a href="https://www.netlify.com/" target="_blank" rel="noopener">Netlify ready</a>
      <a href="#top">Naar boven</a>
    </div>
  </footer>

  <script src="js/app.js"></script>
</body>
</html>
